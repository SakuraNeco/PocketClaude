# Copy to .env and edit if needed. All are OPTIONAL — sensible defaults apply.

# Port the server listens on (default 3000)
# PORT=3000

# Path to the `claude` CLI. Leave unset to auto-detect (Desktop bundle / PATH / common locations).
# CLAUDE_PATH=/usr/local/bin/claude

# Login key for the web UI. Leave unset to auto-generate one into .auth-token (printed at startup).
# CC_AUTH_TOKEN=

# Contact subject for Web Push (VAPID). Any mailto: works; only used by push services.
# VAPID_SUBJECT=mailto:you@example.com
